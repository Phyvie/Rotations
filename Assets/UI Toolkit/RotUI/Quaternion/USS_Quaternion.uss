.wxyz > FloatField {
    flex-grow: 1;
    width: 25%;
}

.wxyz > FloatField > Label {
    width: 10px;
}

.Quaternion__Root {
    padding: 5px; 
}

.Quaternion__ValuesContainer {
    height: 50%; 
}

.Quaternion__EqualsLine {
    height: 18px;
    flex-direction: row;
    margin: 8px; 
}

.Quaternion__AxisAngleContainer {
    height: 50%;
    display: flex; 
    flex-direction: row; 
}

.Quaternion__Real {
    width: 25%;
    display: flex; 
    flex-direction: row; 
    align-items: stretch;
    justify-content: space-around;
}

.Quaternion__Addition {
    width: 45px;
    align-items: stretch;
    justify-content: space-around;
}

.Quaternion__Imaginary {
    width: 75%;
    display: flex; 
    flex-direction: row;
    align-items: stretch;
    justify-content: space-around;
}

.Quaternion__SinHalfAngleContainer {
    width: 25%; 
    flex-direction: column; 
    justify-content: flex-start;
    align-items: stretch;
}

.Quaternion__HalfAngleDescription {
    padding-left: 10px; 
    white-space: normal;
}

.Quaternion__CosAxisContainer {
    width: 75%; 
    flex-direction: column;
    align-items: stretch;
}

.Quaternion__AxisContainer {
    display: flex; 
    flex-direction: row;
    align-items: stretch;
}